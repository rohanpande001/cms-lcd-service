# CMS LCD API Configuration
CMS_LCD_BASE_URL=https://api.coverage.cms.gov/v1

# License agreement flags (set to true to accept CMS terms)
CMS_LICENSE_AMA=true
CMS_LICENSE_ADA=true
CMS_LICENSE_AHA=true

# Token management
TOKEN_REFRESH_BUFFER_MINUTES=5
TOKEN_EXPIRY_MINUTES=60
HTTP_TIMEOUT_SECONDS=30.0

# Application
APP_NAME=CMS LCD Coverage Service
APP_VERSION=1.0.0
LOG_LEVEL=INFO
